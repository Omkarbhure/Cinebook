# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/cinebook?retryWrites=true&w=majority&appName=Cluster0

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_strong_random_secret_here
JWT_EXPIRE=7d

# ── Email (Gmail SMTP) ───────────────────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Twilio (Phone OTP) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_VERIFY_SID=your_twilio_verify_sid

# ── Cloudinary (Avatar uploads) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Client URL (set to your Vercel URL after deploy) ─────────
CLIENT_URL=https://your-app.vercel.app

# ── TMDB ─────────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_key
